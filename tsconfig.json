{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "skills/**/*.ts"],
  "//": "skills/generated/ is agent-written and transpiled by tsx at runtime; keep it out of our typecheck.",
  "exclude": ["skills/generated/**"]
}
